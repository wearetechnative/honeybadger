        }
        .suggestion-id {
            font-weight: bold;
            color: #0c5460;
        }
        .severity {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 3px;
            font-size: 0.9em;
            font-weight: bold;
            margin-left: 10px;
