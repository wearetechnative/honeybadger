# LYNIS SEVERITY CLASSIFICATION FUNCTIONS
# ==============================================================================

# Classify Lynis finding by severity level using keyword-based matching
# Usage: classify_lynis_severity <test_id> <finding_type> <description>
# Arguments:
#   test_id: Lynis test ID (e.g., "PKGS-7392")
#   finding_type: "warning" or "suggestion"
#   description: Finding description text
# Returns: "CRITICAL" | "HIGH" | "MEDIUM" | "LOW"
#
# Severity mapping (ISO27001, NIST, vulnerability management best practices):
# - CRITICAL: Immediate security risk, fix binnen 1 week
#   * Test ID PKGS-7392 (vulnerable packages)
#   * Warnings with critical keywords
# - HIGH: Security-impacting, fix binnen 1 week
#   * All other warnings
#   * Suggestions with high-priority keywords
# - MEDIUM: Configuration hardening, fix binnen 1 maand
#   * Default for suggestions
# - LOW: Optional improvements, best effort
#   * Suggestions with low-priority keywords
classify_lynis_severity() {
    local test_id="$1"
    local finding_type="$2"
    local description="$3"

    # Convert to lowercase for case-insensitive matching
    local desc_lower=$(echo "$description" | tr '[:upper:]' '[:lower:]')

    # CRITICAL: Known critical test IDs
    if [[ "$test_id" == "PKGS-7392" ]]; then
        echo "CRITICAL"
        return 0
    fi

    # CRITICAL: Warnings with critical keywords
    if [[ "$finding_type" == "warning" ]]; then
        if matches_keywords "$desc_lower" "vulnerable unpatched outdated exposed no_encryption no_firewall authentication_failed"; then
            echo "CRITICAL"
            return 0
        fi
        # All other warnings are HIGH
        echo "HIGH"
        return 0
    fi

    # For suggestions: check keyword patterns
    if [[ "$finding_type" == "suggestion" ]]; then
        # LOW: Low-priority keywords
        if matches_keywords "$desc_lower" "consider optional recommended"; then
            echo "LOW"
            return 0
        fi

        # HIGH: High-priority keywords
        if matches_keywords "$desc_lower" "kernel ssh remote permissions access_control update patch"; then
            echo "HIGH"
            return 0
        fi

        # MEDIUM: Default for suggestions
        echo "MEDIUM"
        return 0
    fi

    # Fallback
    echo "MEDIUM"
    return 0
}

# Helper function for case-insensitive keyword matching
# Usage: matches_keywords <text> <keywords>
# Arguments:
#   text: Lowercase text to search in
#   keywords: Space-separated list of keywords (use underscore for spaces in keywords)
# Returns: 0 if any keyword matches, 1 otherwise
matches_keywords() {
    local text="$1"
    local keywords="$2"

    # Convert keywords to array
    local keyword_array=($keywords)

    for keyword in "${keyword_array[@]}"; do
        # Replace underscore with space for multi-word keywords
        local pattern="${keyword//_/ }"

        if echo "$text" | grep -q "$pattern"; then
            return 0
        fi
    done

    return 1
}

