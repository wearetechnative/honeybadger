    echo "Distribution: Arch Linux (Rolling Release)" >> "$report_file"
    echo "Status: YES - ALWAYS CURRENT (if regularly updated)" >> "$report_file"
    echo "Update Stream: ROLLING RELEASE (no versions)" >> "$report_file"
    echo "" >> "$report_file"
    echo "pass"
}

# Analyze Kali status (helper function)
# Returns: "pass", "warning", "fail", or "unknown"
analyze_kali_status() {
    local report_file="$1"

    echo "Distribution: Kali Linux (Debian-based, Rolling)" >> "$report_file"
    echo "Status: YES - ROLLING RELEASE" >> "$report_file"
    echo "Update Stream: ACTIVE" >> "$report_file"
    echo "" >> "$report_file"
    echo "pass"
}

# Analyze kernel status (helper function)
analyze_kernel_status() {
    local report_file="$1"
    local cache_dir="$2"

    echo "=====================================" >> "$report_file"
    echo "SECTION 2: KERNEL VERSION STATUS" >> "$report_file"
    echo "=====================================" >> "$report_file"
    echo "" >> "$report_file"
    echo "Detected Kernel: $KERNEL_VERSION" >> "$report_file"
    echo "" >> "$report_file"
}

# Generate status summary (helper function)
generate_status_summary() {
    local report_file="$1"
    local os_status="$2"
    local cache_dir="$3"

    echo "" >> "$report_file"
    echo "=====================================" >> "$report_file"
    echo "OVERALL SYSTEM STATUS" >> "$report_file"
    echo "=====================================" >> "$report_file"
    echo "" >> "$report_file"

    # Determine overall status
    case "$os_status" in
        pass)
            echo "Result: ✓ PASS" >> "$report_file"
            echo "" >> "$report_file"
            echo "Your system is running a supported operating system version" >> "$report_file"
            echo "with an active update stream. No immediate action required." >> "$report_file"
            echo "" >> "$report_file"
            echo "Recommendations:" >> "$report_file"
            echo "  - Continue applying regular system updates" >> "$report_file"
            echo "  - Monitor for new releases and security updates" >> "$report_file"
            echo "  - Review this report periodically (at least quarterly)" >> "$report_file"
            ;;
        warning)
            echo "Result: ⚠ WARNING" >> "$report_file"
            echo "" >> "$report_file"
            echo "Your system is NOT running the latest version but STILL RECEIVES UPDATES." >> "$report_file"
            echo "An upgrade is recommended but not critical." >> "$report_file"
            echo "" >> "$report_file"
            echo "Recommendations:" >> "$report_file"
            echo "  - Plan an upgrade to the latest stable release" >> "$report_file"
            echo "  - Continue applying security updates in the meantime" >> "$report_file"
            echo "  - Review the upgrade path and test in a staging environment" >> "$report_file"

            # Add specific upgrade recommendation if available
            local latest_release=""
            case "$OS_NAME" in
                NixOS)
                    latest_release=$(get_latest_nixos_release "$cache_dir")
                    [[ -n "$latest_release" ]] && echo "  - Target version: NixOS $latest_release" >> "$report_file"
                    ;;
                Ubuntu)
                    latest_release=$(get_latest_ubuntu_lts "$cache_dir")
                    [[ -n "$latest_release" ]] && echo "  - Target version: Ubuntu $latest_release LTS" >> "$report_file"
                    ;;
            esac
            ;;
        fail)
            echo "Result: ✗ FAIL" >> "$report_file"
            echo "" >> "$report_file"
            echo "CRITICAL: Your system NO LONGER RECEIVES UPDATES (End-of-Life)." >> "$report_file"
            echo "This version has reached EOL and no longer receives security updates." >> "$report_file"
            echo "This poses a significant security risk." >> "$report_file"
            echo "" >> "$report_file"
            echo "URGENT Actions Required:" >> "$report_file"
            echo "  1. DO NOT connect this system to untrusted networks" >> "$report_file"
            echo "  2. Plan an immediate upgrade to a supported version" >> "$report_file"
            echo "  3. If upgrade is not immediately possible:" >> "$report_file"
            echo "     - Isolate the system from the internet" >> "$report_file"
            echo "     - Restrict network access to essential services only" >> "$report_file"
            echo "     - Increase monitoring and auditing" >> "$report_file"
            echo "  4. Document the security risk and create an upgrade timeline" >> "$report_file"

            # Add specific upgrade recommendation if available
            local latest_release=""
            case "$OS_NAME" in
                NixOS)
                    latest_release=$(get_latest_nixos_release "$cache_dir")
                    [[ -n "$latest_release" ]] && echo "  5. Upgrade to: NixOS $latest_release" >> "$report_file"
                    ;;
                Ubuntu)
                    latest_release=$(get_latest_ubuntu_lts "$cache_dir")
                    [[ -n "$latest_release" ]] && echo "  5. Upgrade to: Ubuntu $latest_release LTS" >> "$report_file"
                    ;;
            esac

            echo "" >> "$report_file"
            echo "ISO27001 Compliance Note:" >> "$report_file"
            echo "Running EOL software may violate security policies and compliance" >> "$report_file"
            echo "requirements. Document this finding and escalate appropriately." >> "$report_file"
            ;;
        *)
            echo "Result: ? UNKNOWN" >> "$report_file"
            echo "" >> "$report_file"
            echo "Unable to determine system status. This may be due to:" >> "$report_file"
            echo "  - Unsupported or unrecognized operating system" >> "$report_file"
            echo "  - Missing or incomplete system information" >> "$report_file"
            echo "  - Unable to fetch release data from external sources" >> "$report_file"
            echo "" >> "$report_file"
            echo "Recommendations:" >> "$report_file"
            echo "  - Verify system information is correctly reported" >> "$report_file"
            echo "  - Check internet connectivity for release data updates" >> "$report_file"
            echo "  - Manually verify OS version support status" >> "$report_file"
            echo "  - Consult your OS vendor's support lifecycle documentation" >> "$report_file"
            ;;
    esac

    echo "" >> "$report_file"
    echo "=====================================" >> "$report_file"
    echo "END OF REPORT" >> "$report_file"
    echo "=====================================" >> "$report_file"
}

