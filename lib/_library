# Submit all available reports from output directory
# Usage: submit_all_reports <output_dir>
submit_all_reports() {
    local output_dir="$1"

    if [[ ! -d "$output_dir" ]]; then
        echo "ERROR: Output directory does not exist: $output_dir" >&2
        return 1
    fi

    echo "======================================"
    echo "Submitting reports from: $output_dir"
    echo "======================================"
    echo ""

    # Load configuration
    load_server_config
    echo ""

    # Check if submission is enabled
    if [[ "$SERVER_ENABLED" != "true" ]]; then
        echo "Server submission is disabled (SERVER_ENABLED=false)"
        echo "To enable, set SERVER_ENABLED=true in configuration file"
        return 1
    fi

    # Check if token is configured
    if [[ -z "$SERVER_TOKEN" ]]; then
        echo "ERROR: SERVER_TOKEN is required but not configured"
        echo ""
        echo "The server requires authentication. Please add SERVER_TOKEN to your configuration file:"
        echo "  SERVER_TOKEN=hb_token_your_token_here"
        echo ""
        echo "Configuration locations:"
        echo "  - ./.honeybadger.conf (current directory)"
        echo "  - ~/.honeybadger.conf (user home)"
        echo "  - /etc/honeybadger.conf (system-wide)"
        return 1
    fi

    # Track submission results
    local success_count=0
    local fail_count=0
    local reports_submitted=()
    local reports_failed=()

    # Submit neofetch report
    if submit_report "$output_dir/neofetch.json" "neofetch"; then
        ((success_count++))
        reports_submitted+=("neofetch")
    else
        ((fail_count++))
        reports_failed+=("neofetch")
    fi
    echo ""

    # Submit lynis report
    if submit_report "$output_dir/lynis-report.json" "lynis"; then
        ((success_count++))
        reports_submitted+=("lynis")
    else
        ((fail_count++))
        reports_failed+=("lynis")
    fi
    echo ""

    # Print summary
    echo "======================================"
    echo "Submission Summary"
    echo "======================================"
    echo "Successful: $success_count"
    if [[ ${#reports_submitted[@]} -gt 0 ]]; then
        printf '  - %s\n' "${reports_submitted[@]}"
    fi
    echo ""
    echo "Failed: $fail_count"
    if [[ ${#reports_failed[@]} -gt 0 ]]; then
        printf '  - %s\n' "${reports_failed[@]}"
    fi
    echo ""

    # Exit with appropriate code
    if [[ $success_count -gt 0 ]]; then
        echo "At least one report submitted successfully"
        return 0
    else
        echo "All submissions failed"
        return 1
    fi
}
