# Determine severity based on keywords in description
# Usage: categorize_severity <description>
# Returns: critical, high, medium, low, or unspecified
categorize_severity() {
    local description="$1"
    local desc_lower=$(echo "$description" | tr '[:upper:]' '[:lower:]')

    # Critical keywords
    if [[ "$desc_lower" =~ (root|password|authentication|encryption|firewall|kernel|privilege|exploit|vulnerability|backdoor|malware) ]]; then
        if [[ "$desc_lower" =~ (disabled|not.*enabled|no.*protection|missing|weak|empty|default) ]]; then
            echo "critical"
            return
        fi
    fi

    # High severity keywords
    if [[ "$desc_lower" =~ (security|permission|access|credential|key|certificate|audit|hardening) ]]; then
        if [[ "$desc_lower" =~ (disabled|not.*enabled|missing|weak|insecure) ]]; then
            echo "high"
            return
        fi
    fi

    # Medium severity keywords
    if [[ "$desc_lower" =~ (update|patch|configuration|warning|should|recommend) ]]; then
        echo "medium"
        return
    fi

    # Low severity
    if [[ "$desc_lower" =~ (consider|optional|suggestion|information) ]]; then
        echo "low"
        return
    fi

    # Default
    echo "unspecified"
}

# Generate warnings and suggestions HTML/PDF report
# Usage: generate_warnings_report <lynis_json> <output_base>
# Output: Creates ${output_base}.html and optionally ${output_base}.pdf
generate_warnings_report() {
    local input_json="$1"
    local output_base="$2"
    local output_html="${output_base}.html"
    local output_pdf="${output_base}.pdf"
    local temp_html="/tmp/lynis-warnings-$$.html"

    if [[ ! -f "$input_json" ]]; then
        echo "ERROR: Input file $input_json does not exist"
        return 1
    fi

    # Check jq dependency
    if ! command -v jq >/dev/null 2>&1; then
        echo "ERROR: jq is required for warnings report generation"
        return 1
    fi

    # Extract data from JSON
    local hostname=$(jq -r '.hostname // "Unknown"' "$input_json" 2>/dev/null)
    local os_full=$(jq -r '.os_fullname // .os_name // "Unknown"' "$input_json" 2>/dev/null)
    local report_date=$(jq -r '.report_datetime_start // "Unknown"' "$input_json" 2>/dev/null)
    local lynis_version=$(jq -r '.lynis_version // "Unknown"' "$input_json" 2>/dev/null)
    local warning_count=$(jq -r '.["warning[]"] | length' "$input_json" 2>/dev/null)
    local suggestion_count=$(jq -r '.["suggestion[]"] | length' "$input_json" 2>/dev/null)

    # Categorize suggestions by severity using temp files
    local temp_critical="/tmp/lynis-critical-$$.json"
    local temp_high="/tmp/lynis-high-$$.json"
    local temp_medium="/tmp/lynis-medium-$$.json"
    local temp_low="/tmp/lynis-low-$$.json"
    local temp_unspecified="/tmp/lynis-unspecified-$$.json"

    # Initialize temp files
    echo "[]" > "$temp_critical"
    echo "[]" > "$temp_high"
    echo "[]" > "$temp_medium"
    echo "[]" > "$temp_low"
    echo "[]" > "$temp_unspecified"

    # Categorize each suggestion (using process substitution to avoid subshell)
    if [[ "$suggestion_count" -gt 0 ]]; then
        # Export function for use in subshell
        export -f categorize_severity

        # Process suggestions and categorize them
        jq -c '.["suggestion[]"][] | {id: .id, description: .description}' "$input_json" 2>/dev/null > "/tmp/suggestions-$$.jsonl"

        # Categorize using bash
        while IFS= read -r suggestion; do
            local description=$(echo "$suggestion" | jq -r '.description')
            local severity=$(categorize_severity "$description")
            local id=$(echo "$suggestion" | jq -r '.id')

            # Write to appropriate temp file
            echo "{\"id\":\"$id\",\"description\":$(echo "$description" | jq -Rs .),\"severity\":\"$severity\"}" >> "/tmp/sev-${severity}-$$.jsonl"
        done < "/tmp/suggestions-$$.jsonl"

        # Convert JSONL to JSON arrays and count
        for sev in critical high medium low unspecified; do
            if [[ -f "/tmp/sev-${sev}-$$.jsonl" ]]; then
                jq -s '.' "/tmp/sev-${sev}-$$.jsonl" > "/tmp/lynis-${sev}-$$.json" 2>/dev/null
                rm "/tmp/sev-${sev}-$$.jsonl"
            fi
        done

        # Count each severity
        local critical_count=$(jq -r 'length' "$temp_critical" 2>/dev/null || echo 0)
        local high_count=$(jq -r 'length' "$temp_high" 2>/dev/null || echo 0)
        local medium_count=$(jq -r 'length' "$temp_medium" 2>/dev/null || echo 0)
        local low_count=$(jq -r 'length' "$temp_low" 2>/dev/null || echo 0)
        local unspecified_count=$(jq -r 'length' "$temp_unspecified" 2>/dev/null || echo 0)

        rm -f "/tmp/suggestions-$$.jsonl"
    else
        local critical_count=0
        local high_count=0
        local medium_count=0
        local low_count=0
        local unspecified_count=0
    fi

    # Generate HTML
    cat > "$temp_html" <<'HTML_HEADER'
<!DOCTYPE html>
