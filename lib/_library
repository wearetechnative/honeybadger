# Check disk encryption status from blockdevices.txt
# Usage: check_disk_encryption <output_dir>
# Returns: "Yes (LUKS)" | "Yes (LUKS2)" | "No" | "Unknown"
check_disk_encryption() {
    local output_dir="$1"
    local blockdevices_file="$output_dir/blockdevices.txt"

    if [[ ! -f "$blockdevices_file" ]]; then
        echo "Unknown"
        return 1
    fi

    if grep -q "crypto_LUKS" "$blockdevices_file"; then
        # Check if LUKS2 specifically
        if grep -q "crypto_LUKS 2" "$blockdevices_file"; then
            echo "Yes (LUKS2)"
        else
            echo "Yes (LUKS)"
        fi
        return 0
    else
        echo "No"
        return 1
    fi
}

# Check screen lock status from screenlock-info.txt
# Usage: check_screen_lock_status <output_dir>
# Returns: "Yes (Auto-lock: X minutes)" | "Disabled" | "Timeout too long (X minutes)" | "Unknown"
check_screen_lock_status() {
    local output_dir="$1"
    local screenlock_file="$output_dir/screenlock-info.txt"

    if [[ ! -f "$screenlock_file" ]]; then
        echo "Unknown"
        return 1
    fi

    if grep -q "AUTO-LOCK-STATUS: ENABLED" "$screenlock_file"; then
        # Extract timeout in minutes
        local timeout_line=$(grep "Total time until auto-lock:" "$screenlock_file" | grep -oP '\([0-9]+ minutes\)' | tr -d '()')
        if [[ -z "$timeout_line" ]]; then
            timeout_line=$(grep "Auto-lock timeout:" "$screenlock_file" | grep -oP '[0-9]+ minutes' | head -1)
        fi

        if [[ -n "$timeout_line" ]]; then
            local minutes=$(echo "$timeout_line" | grep -oP '[0-9]+')
            if [[ $minutes -le 15 ]]; then
                echo "Yes (Auto-lock: $timeout_line)"
                return 0
            else
                echo "Timeout too long ($timeout_line)"
                return 1
            fi
        else
            echo "Yes (Auto-lock enabled)"
            return 0
        fi
    else
        echo "Disabled"
        return 1
    fi
}

# Check for active iptables firewall rules
# Usage: check_iptables_firewall
# Returns: 0 if active firewall detected, 1 otherwise
# Detects: NixOS nixos-fw chain + generic non-empty iptables rulesets
check_iptables_firewall() {
    # Check if iptables command is available
    if ! command -v iptables >/dev/null 2>&1; then
        return 1
    fi

    # Check for NixOS nixos-fw chain (common on NixOS systems)
    if sudo iptables -L nixos-fw -n >/dev/null 2>&1; then
        local nixos_fw_rules=$(sudo iptables -L nixos-fw -n 2>/dev/null | grep -v "^Chain" | grep -v "^target" | wc -l)
        if [[ $nixos_fw_rules -gt 0 ]]; then
            return 0  # Active NixOS firewall detected
        fi
    fi

    # Check for generic iptables rules (non-default chains or rules)
    # Look for INPUT chain with actual rules (not just policy)
    local input_rules=$(sudo iptables -L INPUT -n 2>/dev/null | grep -v "^Chain" | grep -v "^target" | wc -l)
    if [[ $input_rules -gt 0 ]]; then
        return 0  # Active iptables rules detected
    fi

    return 1  # No active firewall detected
}

# Check for active nftables firewall rules
# Usage: check_nftables_firewall
# Returns: 0 if active firewall detected, 1 otherwise
check_nftables_firewall() {
    # Check if nft command is available
    if ! command -v nft >/dev/null 2>&1; then
        return 1
    fi

    # Check for any nftables ruleset
    local nft_rules=$(sudo nft list ruleset 2>/dev/null | grep -v "^$" | wc -l)
    if [[ $nft_rules -gt 0 ]]; then
        return 0  # Active nftables rules detected
    fi

    return 1  # No active nftables detected
}

# Check firewall status from lynis-report.json with fallback detection
# Usage: check_firewall_status <output_dir>
# Returns: "Yes" | "No" | "Unknown"
# Exit code: 0 if firewall active, 1 otherwise
#
# Detection strategy:
# 1. Primary: Check Lynis firewall_active field
# 2. Fallback (if Lynis reports 0): Direct iptables/nftables check
#    - Detects NixOS nixos-fw chain
#    - Detects custom iptables/nftables configurations
check_firewall_status() {
    local output_dir="$1"
    local lynis_file="$output_dir/lynis-report.json"

    if [[ ! -f "$lynis_file" ]] || ! command -v jq >/dev/null 2>&1; then
        echo "Unknown"
        return 1
    fi

    # Primary detection: Lynis firewall_active field
    local firewall_active=$(jq -r '.firewall_active // "0"' "$lynis_file" 2>/dev/null)

    if [[ "$firewall_active" == "1" ]]; then
        echo "Yes"
        return 0
    fi

    # Fallback detection: Direct iptables/nftables check
    # Only runs when Lynis reports no firewall (eliminates false negatives)
    if check_iptables_firewall 2>/dev/null; then
        echo "Yes (iptables)"
        return 0
    fi

    if check_nftables_firewall 2>/dev/null; then
        echo "Yes (nftables)"
        return 0
    fi

    # No firewall detected by either method
    echo "No"
    return 1
}

# Detect if system is NixOS
# Usage: is_nixos <output_dir>
# Returns: 0 if NixOS, 1 otherwise
is_nixos() {
    local output_dir="$1"

    # Check lynis-report.json first (most authoritative)
    if [[ -f "$output_dir/lynis-report.json" ]] && command -v jq >/dev/null 2>&1; then
        local os_name=$(jq -r '.os_name // ""' "$output_dir/lynis-report.json" 2>/dev/null)
        if [[ "$os_name" =~ "NixOS" ]]; then
            return 0
        fi
    fi

    # Fallback: check neofetch.json
    if [[ -f "$output_dir/neofetch.json" ]] && command -v jq >/dev/null 2>&1; then
        local os=$(jq -r '.os // ""' "$output_dir/neofetch.json" 2>/dev/null)
        if [[ "$os" =~ "NixOS" ]]; then
            return 0
        fi
    fi

    return 1
}

# Check NixOS supply chain security status
# Usage: check_nixos_supply_chain <output_dir>
# Returns: Status string (PASS/FAIL/Unknown)
# Exit code: 0 if PASS, 1 if FAIL or Unknown
#
# Also sets global variables for detailed reporting:
#   NIXOS_SUPPLY_CHAIN_STATUS - PASS/FAIL/Unknown
#   NIXOS_SUPPLY_CHAIN_ISSUES - Array of failure reasons (if FAIL)
#   NIXOS_SUPPLY_CHAIN_STORE_OK - true/false/unknown (store integrity)
check_nixos_supply_chain() {
    local output_dir="$1"
    local audit_file="$output_dir/nix-supply-chain-audit.txt"

    # Return Unknown if audit file doesn't exist
    if [[ ! -f "$audit_file" ]]; then
        NIXOS_SUPPLY_CHAIN_STATUS="Unknown"
        NIXOS_SUPPLY_CHAIN_ISSUES=()
        NIXOS_SUPPLY_CHAIN_STORE_OK="unknown"
        echo "Unknown"
        return 1
    fi

    # Parse result from audit output
    if grep -q "Result: PASS" "$audit_file" 2>/dev/null; then
        NIXOS_SUPPLY_CHAIN_STATUS="PASS"
        NIXOS_SUPPLY_CHAIN_ISSUES=()

        # Extract store integrity status
        if grep -q "Store integrity: OK" "$audit_file" 2>/dev/null; then
            NIXOS_SUPPLY_CHAIN_STORE_OK="true"
        else
            NIXOS_SUPPLY_CHAIN_STORE_OK="false"
        fi

        echo "PASS"
        return 0

    elif grep -q "Result: FAIL" "$audit_file" 2>/dev/null; then
        NIXOS_SUPPLY_CHAIN_STATUS="FAIL"

        # Extract failure reasons from "Issues identified:" section
        NIXOS_SUPPLY_CHAIN_ISSUES=()
        local in_issues=false
        while IFS= read -r line; do
            if [[ "$line" =~ "Issues identified:" ]]; then
                in_issues=true
                continue
            fi
            if $in_issues; then
                # Stop at empty line or next section
                if [[ -z "$line" ]] || [[ "$line" =~ ^=== ]]; then
                    break
                fi
                # Extract issue (remove leading "- ")
                local issue=$(echo "$line" | sed 's/^- //')
                if [[ -n "$issue" ]]; then
                    NIXOS_SUPPLY_CHAIN_ISSUES+=("$issue")
                fi
            fi
        done < "$audit_file"

        # Extract store integrity status
        if grep -q "Store integrity: OK" "$audit_file" 2>/dev/null; then
            NIXOS_SUPPLY_CHAIN_STORE_OK="true"
        elif grep -q "Store integrity: WARNING" "$audit_file" 2>/dev/null; then
            NIXOS_SUPPLY_CHAIN_STORE_OK="false"
        else
            NIXOS_SUPPLY_CHAIN_STORE_OK="unknown"
        fi

        echo "FAIL"
        return 1
    else
        NIXOS_SUPPLY_CHAIN_STATUS="Unknown"
        NIXOS_SUPPLY_CHAIN_ISSUES=()
        NIXOS_SUPPLY_CHAIN_STORE_OK="unknown"
        echo "Unknown"
        return 1
    fi
}

# Check hardening score from lynis-report.json
# Usage: check_hardening_score <output_dir>
# Returns: score value (0-100) or "Unknown"
# Exit code: always 0 (informational only, no pass/fail)
check_hardening_score() {
    local output_dir="$1"
    local lynis_file="$output_dir/lynis-report.json"

    if [[ ! -f "$lynis_file" ]] || ! command -v jq >/dev/null 2>&1; then
        echo "Unknown"
        return 0
    fi

    local score=$(jq -r '.hardening_index // "Unknown"' "$lynis_file" 2>/dev/null)

    if [[ "$score" == "Unknown" ]] || [[ ! "$score" =~ ^[0-9]+$ ]]; then
        echo "Unknown"
        return 0
    fi

    echo "$score"
    return 0
}

# Check for vulnerable packages from lynis-report.json
