# Generate ISO27001 compliance report
# Usage: generate_compliance_report <output_dir>
# Generates: honeybadger-{user}-{date}-compliance.md
generate_compliance_report() {
    local output_dir="$1"

    if [[ ! -d "$output_dir" ]]; then
        echo "ERROR: Directory $output_dir does not exist" >&2
        return 1
    fi

    # Extract username and date from output directory name
    # Format: output-{hostname}-{user}-{date}
    local dirname=$(basename "$output_dir")
    local report_file=""

    if [[ "$dirname" =~ output-([^-]+)-([^-]+)-(.+)$ ]]; then
        local hostname="${BASH_REMATCH[1]}"
        local username="${BASH_REMATCH[2]}"
        local datepart="${BASH_REMATCH[3]}"
        report_file="honeybadger-${username}-${datepart}-compliance.md"
    else
        # Fallback
        report_file="honeybadger-compliance-$(date +%d-%m-%Y).md"
    fi

    # Run compliance checks
    # Note: Capture exit code AFTER each function call, not on same line as local declaration
    local disk_enc
    disk_enc=$(check_disk_encryption "$output_dir")
    local disk_enc_status=$?

    local screen_lock
    screen_lock=$(check_screen_lock_status "$output_dir")
    local screen_lock_status=$?

    local firewall
    firewall=$(check_firewall_status "$output_dir")
    local firewall_status=$?

    local hardening
    hardening=$(check_hardening_score "$output_dir")

    local vulnerable_pkgs
    vulnerable_pkgs=$(check_vulnerable_packages "$output_dir")
    local vulnerable_status=$?

    local lynis_exists
    lynis_exists=$(check_lynis_scan_exists "$output_dir")

    # Check NixOS supply chain security (if NixOS)
    local nixos_supply_chain=""
    local nixos_supply_chain_status=1
    if is_nixos "$output_dir"; then
        nixos_supply_chain=$(check_nixos_supply_chain "$output_dir")
        nixos_supply_chain_status=$?
    fi

    # Get hostname and OS info from lynis-report.json if available
    local hostname="Unknown"
    local os_full="Unknown"
    local scan_date="Unknown"

    if [[ -f "$output_dir/lynis-report.json" ]] && command -v jq >/dev/null 2>&1; then
        hostname=$(jq -r '.hostname // "Unknown"' "$output_dir/lynis-report.json" 2>/dev/null)
        os_full=$(jq -r '.os_fullname // .os_name // "Unknown"' "$output_dir/lynis-report.json" 2>/dev/null)
        scan_date=$(jq -r '.report_datetime_start // "Unknown"' "$output_dir/lynis-report.json" 2>/dev/null)
    fi

    # Calculate overall compliance status
    local compliance_status=""
    local critical_issues=()

    # Critical checks
    if [[ $disk_enc_status -ne 0 ]] || [[ "$disk_enc" == "No" ]]; then
        critical_issues+=("Geen disk encryptie")
    fi
    if [[ $firewall_status -ne 0 ]] || [[ "$firewall" == "No" ]]; then
        critical_issues+=("Geen firewall")
    fi
    if [[ $vulnerable_status -ne 0 ]] || [[ "$vulnerable_pkgs" == "Yes" ]]; then
        critical_issues+=("Kwetsbare software")
    fi
    if is_nixos "$output_dir" && [[ $nixos_supply_chain_status -ne 0 ]] || [[ "$nixos_supply_chain" == "FAIL" ]]; then
        critical_issues+=("Insecure NixOS supply chain")
    fi

    # Determine overall status
    if [[ ${#critical_issues[@]} -gt 0 ]]; then
        compliance_status="❌ Niet compliant"
    elif [[ $screen_lock_status -ne 0 ]] || [[ "$screen_lock" == "Disabled" ]]; then
        compliance_status="⚠️ Gedeeltelijk compliant"
    else
        compliance_status="✅ Compliant"
    fi

    # Calculate deadline (scan date + 1 week if critical issues)
    local deadline="N.A."
    if [[ ${#critical_issues[@]} -gt 0 ]]; then
        if [[ "$scan_date" != "Unknown" ]]; then
            # Parse scan date and add 7 days
            local scan_epoch=$(date -d "$scan_date" +%s 2>/dev/null || echo "")
            if [[ -n "$scan_epoch" ]]; then
                local deadline_epoch=$((scan_epoch + 604800))  # 7 days in seconds
                deadline=$(date -d "@$deadline_epoch" +"%Y-%m-%d" 2>/dev/null || echo "1 week from scan")
            else
                deadline="1 week from scan"
            fi
        else
            deadline="1 week from scan"
        fi
    fi

    # Pre-calculate status icons to avoid issues with command substitution in heredoc
    local disk_icon=$(status_icon $disk_enc_status)
    local screen_icon=$(status_icon $screen_lock_status)
    local firewall_icon=$(status_icon $firewall_status)
    local lynis_icon=$(status_icon $([ "$lynis_exists" == "Yes" ] && echo 0 || echo 1))
    local vuln_icon=$(status_icon $vulnerable_status)
    local nixos_supply_icon=""
    if is_nixos "$output_dir"; then
        nixos_supply_icon=$(status_icon $nixos_supply_chain_status)
    fi

    # Generate the report
    cat > "$report_file" <<EOF
# ISO27001 Laptop Compliance Report

**Eigenaar:** ${username:-Unknown}
**Hostname:** $hostname
**Scan datum:** $scan_date
**OS:** $os_full

---

## 📋 Compliance Checklist

| Vereiste (ISO27001) | Status | Bevinding |
|---------------------|--------|-----------|
| Disk encryptie | $disk_icon | $disk_enc |
| Screen lock | $screen_icon | $screen_lock |
| Firewall | $firewall_icon | $firewall |
| Lynis malware scan | $lynis_icon | $lynis_exists |
| MFA remote access | ⚠️ | Niet geverifieerd in scan |
| Kwetsbare software | $vuln_icon | $vulnerable_pkgs |
| Hardening score | ℹ️ | $hardening/100 |
EOF

    # Add NixOS supply chain row if system is NixOS
    if is_nixos "$output_dir"; then
        local supply_chain_display="$nixos_supply_chain"
        if [[ "$nixos_supply_chain" == "PASS" ]]; then
            supply_chain_display="Secure (signatures enforced)"
        elif [[ "$nixos_supply_chain" == "FAIL" ]]; then
            supply_chain_display="Insecure"
        fi
        cat >> "$report_file" <<EOF
| NixOS Supply Chain | $nixos_supply_icon | $supply_chain_display |
EOF
    fi

    cat >> "$report_file" <<EOF

---

## 💻 Systeeminformatie

EOF

    # Include OS/Kernel status if available
    if [[ -f "$output_dir/os-kernel-status.txt" ]]; then
        echo "### OS & Kernel Status" >> "$report_file"
        echo "" >> "$report_file"
        echo '```' >> "$report_file"
        cat "$output_dir/os-kernel-status.txt" >> "$report_file"
        echo '```' >> "$report_file"
        echo "" >> "$report_file"
    fi

    # Include Asset Inventory if available
    if [[ -f "$output_dir/asset-inventory.txt" ]]; then
        echo "### Asset Inventory" >> "$report_file"
        echo "" >> "$report_file"
        echo '```' >> "$report_file"
        cat "$output_dir/asset-inventory.txt" >> "$report_file"
        echo '```' >> "$report_file"
        echo "" >> "$report_file"
    fi

    # Include NixOS Supply Chain Audit if available
    if is_nixos "$output_dir" && [[ -f "$output_dir/nix-supply-chain-audit.txt" ]]; then
        echo "### NixOS Supply Chain Audit" >> "$report_file"
        echo "" >> "$report_file"
        echo '```' >> "$report_file"
        cat "$output_dir/nix-supply-chain-audit.txt" >> "$report_file"
        echo '```' >> "$report_file"
        echo "" >> "$report_file"
    fi

    cat >> "$report_file" <<EOF
---

## 🔴 Acties Vereist

EOF

    # Add action summary from lynis findings
    if [[ -f "$output_dir/lynis-report.json" ]] && command -v jq >/dev/null 2>&1; then
        # Count findings by severity (will be done by generate_lynis_actions_report)
        # For now, just reference the actions file
        echo "Zie \`${report_file/compliance/actions}\` voor gedetailleerde actielijst." >> "$report_file"
        echo "" >> "$report_file"
    fi

    # Critical issues
    if [[ ${#critical_issues[@]} -gt 0 ]]; then
        echo "### Kritiek (binnen 1 week)" >> "$report_file"
        for issue in "${critical_issues[@]}"; do
            echo "- [ ] $issue" >> "$report_file"
        done
        echo "" >> "$report_file"
    fi

    cat >> "$report_file" <<EOF
---

## 📊 Samenvatting

**Compliance:** $compliance_status
**Blocker:** ${critical_issues[0]:-Geen}
**Deadline:** $deadline

---

*Rapport volgens TN-ISO27-EN-PLCY-05.00 (sectie 3.2, 7.1, 8.1)*
EOF

    echo "✓ Compliance report generated: $report_file"
    return 0
}

