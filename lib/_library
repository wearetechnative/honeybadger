    fi

    # Add suggestions section
    cat >> "$temp_html" <<'SUGGESTIONS_HEADER'
    <h2>💡 Suggestions</h2>
SUGGESTIONS_HEADER

    if [[ "$suggestion_count" -gt 0 ]]; then
        jq -r '.["suggestion[]"] | .[] |
            "<div class=\"suggestion\">" +
            "<span class=\"suggestion-id\">" + .id + "</span>" +
            (if .severity and .severity != "NA" and .severity != null then
                " <span class=\"severity severity-" + (.severity | ascii_downcase) + "\">" + .severity + "</span>"
            else "" end) +
            "<p>" + .description + "</p>" +
            "</div>"' "$input_json" >> "$temp_html" 2>/dev/null
    else
        echo '<div class="no-issues">✓ No suggestions. System is well configured!</div>' >> "$temp_html"
    fi

    # Add footer
    cat >> "$temp_html" <<'HTML_FOOTER'
    <div class="footer">
        <p>Generated by Honeybadger - Personal Device Audit Tool</p>
        <p>🦡 Make your computer as tough as a honeybadger</p>
        <p><a href="https://github.com/wearetechnative/personal-device-audit">github.com/wearetechnative/personal-device-audit</a></p>
    </div>
</body>
</html>
HTML_FOOTER

    # Always save HTML
    cp "$temp_html" "$output_html"
    echo "✓ HTML report generated: $output_html"

    # Try to convert HTML to PDF using Docker container with wkhtmltopdf
    echo "Converting HTML to PDF using Docker..."
    local html_dir=$(dirname "$output_html")
    local html_filename=$(basename "$output_html")
    local pdf_filename=$(basename "$output_pdf")

    docker run --rm \
        -v "$html_dir:/data:rw" \
        --entrypoint /usr/local/bin/wkhtmltopdf \
        wearetechnative/lynis-report-converter:latest \
        --quiet --enable-local-file-access \
        "/data/$html_filename" "/data/$pdf_filename" >/dev/null 2>&1

    # Check if PDF was successfully created
    if [[ -f "$output_pdf" ]]; then
        # Fix ownership (Docker runs as root, so PDF is owned by root)
        chmod 644 "$output_pdf" 2>/dev/null || true
        chown --reference="$output_html" "$output_pdf" 2>/dev/null || true
        echo "✓ PDF report generated: $output_pdf"
    else
        echo "⚠ PDF conversion failed, HTML version available at: $output_html"
    fi

    # Cleanup
    rm -f "$temp_html"
    return 0
}

