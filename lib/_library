# Scan system for CVE vulnerabilities using OS-appropriate tool
# Usage: scan_cve_vulnerabilities <output_directory>
scan_cve_vulnerabilities() {
    local output_dir="$1"

    if [[ -z "$output_dir" ]]; then
        echo "ERROR: Output directory not specified for CVE scan"
        return 1
    fi

    # Detect OS type from neofetch.json or system info
    local os_name=""
    if [[ -f "$output_dir/neofetch.json" ]]; then
        os_name=$(jq -r '.os // empty' "$output_dir/neofetch.json" 2>/dev/null | awk '{print $1}')
    fi

    # Fallback to system detection
    if [[ -z "$os_name" ]] && [[ -f /etc/os-release ]]; then
        os_name=$(grep "^ID=" /etc/os-release | cut -d= -f2 | tr -d '"')
    fi

    echo "Scanning for CVE vulnerabilities..."

    # Choose scanning tool based on OS
    if [[ "$os_name" == "NixOS" ]] || [[ -f /etc/nixos/configuration.nix ]]; then
        scan_vulnix "$output_dir"
    else
        scan_trivy "$output_dir"
    fi
}

# Scan NixOS system with vulnix
# Usage: scan_vulnix <output_directory>
scan_vulnix() {
    local output_dir="$1"
    local output_file="$output_dir/vulnix.json"

    # Check if vulnix is available
    if ! command -v vulnix >/dev/null 2>&1; then
        echo "INFO: vulnix not installed, CVE scanning skipped"
        echo "Install with: nix-env -iA nixpkgs.vulnix"
        return 0
    fi

    echo "Running vulnix scan on NixOS system..."

    # Run vulnix with timeout (5 minutes)
    # Note: vulnix returns exit code 2 when vulnerabilities are found
    timeout 300 vulnix --json /run/current-system > "$output_file" 2>&1
    local exit_code=$?

    # Check if output file was created and is valid JSON
    if [[ -f "$output_file" ]] && [[ -s "$output_file" ]]; then
        # Verify it's valid JSON
        if jq empty "$output_file" >/dev/null 2>&1; then
            echo "✓ CVE scan completed: $output_file"
            if [[ $exit_code -eq 2 ]]; then
                echo "  (vulnerabilities detected)"
            fi
            return 0
        fi
    fi

    # Scan failed or timed out
    if [[ $exit_code -eq 124 ]]; then
        echo "⚠ CVE scan timeout (5 minutes exceeded), scan incomplete"
    else
        echo "⚠ CVE scan failed with exit code $exit_code"
    fi
    # Remove incomplete output
    rm -f "$output_file"
    return 1
}

# Scan filesystem with trivy
# Usage: scan_trivy <output_directory>
scan_trivy() {
    local output_dir="$1"
    local output_file="$output_dir/trivy.json"

    # Check if trivy is available
    if ! command -v trivy >/dev/null 2>&1; then
        echo "INFO: trivy not installed, CVE scanning skipped"
        echo "Install instructions:"
        echo "  Ubuntu/Debian: wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | sudo apt-key add - && echo 'deb https://aquasecurity.github.io/trivy-repo/deb \$(lsb_release -sc) main' | sudo tee /etc/apt/sources.list.d/trivy.list && sudo apt update && sudo apt install trivy"
        echo "  Arch Linux: yay -S trivy"
        echo "  macOS: brew install trivy"
        return 0
    fi

    echo "Running trivy scan on filesystem..."

    # Run trivy with timeout (5 minutes)
    # --scanners vuln: Only scan for vulnerabilities (not misconfigs or secrets)
    # --format json: Output JSON format
    # --quiet: Suppress progress output
    # Note: trivy may return non-zero exit code when vulnerabilities are found
    timeout 300 trivy rootfs --format json --scanners vuln --quiet / > "$output_file" 2>&1
    local exit_code=$?

    # Check if output file was created and is valid JSON
    if [[ -f "$output_file" ]] && [[ -s "$output_file" ]]; then
        # Verify it's valid JSON
        if jq empty "$output_file" >/dev/null 2>&1; then
            echo "✓ CVE scan completed: $output_file"
            if [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 124 ]]; then
                echo "  (vulnerabilities may have been detected)"
            fi
            return 0
        fi
    fi

    # Scan failed or timed out
    if [[ $exit_code -eq 124 ]]; then
        echo "⚠ CVE scan timeout (5 minutes exceeded), scan incomplete"
    else
        echo "⚠ CVE scan failed with exit code $exit_code"
    fi
    # Remove incomplete output
    rm -f "$output_file"
    return 1
}

# Generate CVE summary report from scan results
# Usage: generate_cve_summary <output_directory>
generate_cve_summary() {
    local output_dir="$1"
    local vulnix_file="$output_dir/vulnix.json"
    local trivy_file="$output_dir/trivy.json"
    local summary_file="$output_dir/cve-summary.txt"

    if [[ -z "$output_dir" ]]; then
        echo "ERROR: Output directory not specified for CVE summary"
        return 1
    fi

    # Check which scan file exists
    if [[ -f "$vulnix_file" ]]; then
        generate_vulnix_summary "$vulnix_file" "$summary_file"
    elif [[ -f "$trivy_file" ]]; then
        generate_trivy_summary "$trivy_file" "$summary_file"
    else
        # No CVE scan results, skip summary
        return 0
    fi
}

# Generate summary from vulnix results
# Usage: generate_vulnix_summary <vulnix_json> <output_file>
generate_vulnix_summary() {
    local vulnix_json="$1"
    local output_file="$2"

    if ! command -v jq >/dev/null 2>&1; then
        echo "ERROR: jq not available, cannot generate CVE summary"
        return 1
    fi

    # Parse vulnix JSON (array of CVE objects)
    local total=$(jq 'length' "$vulnix_json" 2>/dev/null || echo "0")

    # Vulnix doesn't provide severity ratings, all CVEs are listed
    # We'll count them as "unrated" since vulnix focuses on NixOS packages

    {
        echo "======================================"
        echo "  CVE VULNERABILITY SCAN SUMMARY"
        echo "======================================"
        echo ""
        echo "Scan Date: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "Tool: vulnix (NixOS vulnerability scanner)"
        echo ""
        echo "Total CVEs Found: $total"
        echo ""
        if [[ $total -gt 0 ]]; then
            echo "Status: ⚠ VULNERABILITIES DETECTED"
            echo ""
            echo "Note: Vulnix reports CVEs for Nix packages."
            echo "Review vulnix.json for detailed vulnerability information."
            echo ""
            echo "Action Required:"
            echo "  - Review detected CVEs in vulnix.json"
            echo "  - Update affected packages: nixos-rebuild switch --upgrade"
            echo "  - Check NixOS security advisories"
        else
            echo "Status: ✓ NO VULNERABILITIES DETECTED"
        fi
        echo ""
        echo "======================================"
    } > "$output_file"

    echo "✓ CVE summary generated: $output_file"
}

# Generate summary from trivy results
# Usage: generate_trivy_summary <trivy_json> <output_file>
generate_trivy_summary() {
    local trivy_json="$1"
    local output_file="$2"

    if ! command -v jq >/dev/null 2>&1; then
        echo "ERROR: jq not available, cannot generate CVE summary"
        return 1
    fi

    # Parse trivy JSON structure
    # Trivy JSON has: .Results[].Vulnerabilities[] with .Severity field
    local critical=$(jq '[.Results[]?.Vulnerabilities[]? | select(.Severity == "CRITICAL")] | length' "$trivy_json" 2>/dev/null || echo "0")
    local high=$(jq '[.Results[]?.Vulnerabilities[]? | select(.Severity == "HIGH")] | length' "$trivy_json" 2>/dev/null || echo "0")
    local medium=$(jq '[.Results[]?.Vulnerabilities[]? | select(.Severity == "MEDIUM")] | length' "$trivy_json" 2>/dev/null || echo "0")
    local low=$(jq '[.Results[]?.Vulnerabilities[]? | select(.Severity == "LOW")] | length' "$trivy_json" 2>/dev/null || echo "0")
    local total=$((critical + high + medium + low))

    {
        echo "======================================"
        echo "  CVE VULNERABILITY SCAN SUMMARY"
        echo "======================================"
        echo ""
        echo "Scan Date: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "Tool: trivy (filesystem vulnerability scanner)"
        echo ""
        echo "Total CVEs Found: $total"
        echo ""
        echo "Severity Breakdown:"
        echo "  Critical: $critical"
        echo "  High:     $high"
        echo "  Medium:   $medium"
        echo "  Low:      $low"
        echo ""

        if [[ $critical -gt 0 ]] || [[ $high -gt 0 ]]; then
            echo "Status: ✗ ACTION REQUIRED - Critical/High CVEs Detected"
            echo ""
            echo "Action Required:"
            echo "  - Review critical and high severity CVEs in trivy.json"
            echo "  - Update affected packages immediately"
            echo "  - Apply security patches as soon as possible"
        elif [[ $total -gt 0 ]]; then
            echo "Status: ⚠ VULNERABILITIES DETECTED (Medium/Low)"
            echo ""
            echo "Recommendation:"
            echo "  - Review detected CVEs in trivy.json"
            echo "  - Plan updates during next maintenance window"
        else
            echo "Status: ✓ NO VULNERABILITIES DETECTED"
        fi
        echo ""
        echo "======================================"
    } > "$output_file"

    echo "✓ CVE summary generated: $output_file"
}

