# Generate Lynis security actions report organized by severity
# Usage: generate_lynis_actions_report <output_dir>
# Generates: honeybadger-{user}-{date}-actions.md
generate_lynis_actions_report() {
    local output_dir="$1"

    if [[ ! -d "$output_dir" ]]; then
        echo "ERROR: Directory $output_dir does not exist" >&2
        return 1
    fi

    local lynis_file="$output_dir/lynis-report.json"
    if [[ ! -f "$lynis_file" ]] || ! command -v jq >/dev/null 2>&1; then
        echo "ERROR: lynis-report.json not found or jq not available" >&2
        return 1
    fi

    # Extract username and date from output directory name
    local dirname=$(basename "$output_dir")
    local report_file=""

    if [[ "$dirname" =~ output-([^-]+)-([^-]+)-(.+)$ ]]; then
        local hostname="${BASH_REMATCH[1]}"
        local username="${BASH_REMATCH[2]}"
        local datepart="${BASH_REMATCH[3]}"
        report_file="honeybadger-${username}-${datepart}-actions.md"
    else
        report_file="honeybadger-actions-$(date +%d-%m-%Y).md"
    fi

    # Get metadata
    local hostname=$(jq -r '.hostname // "Unknown"' "$lynis_file" 2>/dev/null)
    local scan_date=$(jq -r '.report_datetime_start // "Unknown"' "$lynis_file" 2>/dev/null)

    # Extract warnings and suggestions
    local temp_findings="/tmp/lynis-findings-$$.json"

    jq -r '
        ((.["warning[]"] // []) | to_entries | map({
            test_id: (.key | tostring),
            type: "warning",
            description: .value
        })) +
        ((.["suggestion[]"] // []) | to_entries | map({
            test_id: .value.id // (.key | tostring),
            type: "suggestion",
            description: .value.description // .value
        }))
    ' "$lynis_file" > "$temp_findings" 2>/dev/null

    # Classify findings by severity
    declare -A severity_counts
    declare -A severity_findings
    severity_counts[CRITICAL]=0
    severity_counts[HIGH]=0
    severity_counts[MEDIUM]=0
    severity_counts[LOW]=0

    while IFS= read -r finding; do
        local test_id=$(echo "$finding" | jq -r '.test_id')
        local type=$(echo "$finding" | jq -r '.type')
        local description=$(echo "$finding" | jq -r '.description')

        local severity=$(classify_lynis_severity "$test_id" "$type" "$description")

        severity_counts[$severity]=$((${severity_counts[$severity]} + 1))
        severity_findings[$severity]+="$finding"$'\n'
    done < <(jq -c '.[]' "$temp_findings" 2>/dev/null)

    # Only report CRITICAL and HIGH (exclude MEDIUM and LOW for focus)
    local total=$((${severity_counts[CRITICAL]} + ${severity_counts[HIGH]}))

    # Generate report
    cat > "$report_file" <<EOF
# Lynis Security Actions

**Scan datum:** $scan_date
**Hostname:** $hostname
**Totaal:** $total acties (${severity_counts[CRITICAL]} Critical, ${severity_counts[HIGH]} High)

*Note: Medium en Low severity findings zijn niet opgenomen in dit rapport (focus op urgente items)*

---

EOF

    # Check if there are any CRITICAL/HIGH findings
    if [[ $total -eq 0 ]]; then
        cat >> "$report_file" <<EOF
## ✅ Geen Security Findings

Geen warnings of suggestions gevonden. Systeem is goed geconfigureerd!

---

*Zie compliance report voor overall status*
EOF
        rm -f "$temp_findings"
        echo "✓ Actions report generated: $report_file (no findings)"
        return 0
    fi

    # Generate sections by severity (only CRITICAL and HIGH - Medium/Low excluded for focus)
    for severity in CRITICAL HIGH; do
        local count=${severity_counts[$severity]}
        if [[ $count -eq 0 ]]; then
            continue
        fi

        # Determine icon and deadline
        local icon=""
        local deadline=""
        case $severity in
            CRITICAL)
                icon="🔴"
                deadline="(fix binnen 1 week)"
                ;;
            HIGH)
                icon="🟠"
                deadline="(fix binnen 1 week)"
                ;;
            MEDIUM)
                icon="🟡"
                deadline="(fix binnen 1 maand)"
                ;;
            LOW)
                icon="🟢"
                deadline="(best effort)"
                ;;
        esac

        cat >> "$report_file" <<EOF
## $icon $severity $deadline

EOF

        # Output findings for this severity
        echo "${severity_findings[$severity]}" | while IFS= read -r finding_json; do
            if [[ -z "$finding_json" ]]; then
                continue
            fi

            local test_id=$(echo "$finding_json" | jq -r '.test_id')
            local description=$(echo "$finding_json" | jq -r '.description')

            cat >> "$report_file" <<EOF
### $test_id

$description

EOF
        done

        echo "---" >> "$report_file"
        echo "" >> "$report_file"
    done

    cat >> "$report_file" <<EOF

*Zie compliance report voor overall status*
EOF

    rm -f "$temp_findings"
    echo "✓ Actions report generated: $report_file"
    return 0
}
