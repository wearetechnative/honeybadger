# Generate asset inventory table from available data
# Usage: generate_asset_inventory <output_dir>
generate_asset_inventory() {
    local output_dir="$1"
    local report_file="$output_dir/asset-inventory.txt"

    if [[ ! -d "$output_dir" ]]; then
        echo "ERROR: Directory $output_dir does not exist"
        return 1
    fi

    # Extract data from available files
    local hostname=""
    local os_full=""
    local os_version=""
    local kernel=""
    local model=""
    local serial=""
    local disk_encrypted="Unknown"
    local screen_lock="Unknown"
    local nix_installed="Unknown"
    local malware_scanner="Unknown"
    local firewall_active="Unknown"
    local os_uptodate="Unknown"
    local owner=""
    local report_date=""

    # Get hostname and OS info from lynis-report.json
    if [[ -f "$output_dir/lynis-report.json" ]] && command -v jq >/dev/null 2>&1; then
        hostname=$(jq -r '.hostname // "Unknown"' "$output_dir/lynis-report.json" 2>/dev/null)
        os_full=$(jq -r '.os_fullname // .os_name // "Unknown"' "$output_dir/lynis-report.json" 2>/dev/null)
        os_version=$(jq -r '.os_version // "Unknown"' "$output_dir/lynis-report.json" 2>/dev/null)
        malware_scanner=$(jq -r '.malware_scanner_installed // "0"' "$output_dir/lynis-report.json" 2>/dev/null)
        [[ "$malware_scanner" == "1" ]] && malware_scanner="Yes" || malware_scanner="No"
        firewall_active=$(jq -r '.firewall_active // "0"' "$output_dir/lynis-report.json" 2>/dev/null)
        [[ "$firewall_active" == "1" ]] && firewall_active="Yes" || firewall_active="No"
    fi

    # Get hardware info from neofetch.json or neofetch.txt
    if [[ -f "$output_dir/neofetch.json" ]]; then
        # Extract from JSON
        owner=$(jq -r '.user // empty' "$output_dir/neofetch.json" 2>/dev/null)
        model=$(jq -r '.host // empty' "$output_dir/neofetch.json" 2>/dev/null)
        kernel=$(jq -r '.kernel // empty' "$output_dir/neofetch.json" 2>/dev/null)

        # If hostname not found in lynis, get from neofetch JSON
        if [[ "$hostname" == "Unknown" ]]; then
            local json_hostname=$(jq -r '.hostname // empty' "$output_dir/neofetch.json" 2>/dev/null)
            [[ -n "$json_hostname" ]] && hostname="$json_hostname"
        fi
    elif [[ -f "$output_dir/neofetch.txt" ]]; then
        # Fallback to text parsing for backward compatibility
        owner=$(grep "^[a-z]*@" "$output_dir/neofetch.txt" | cut -d'@' -f1 | head -1)
        model=$(grep "^Host:" "$output_dir/neofetch.txt" | sed 's/^Host: //' | head -1)
        kernel=$(grep "^Kernel:" "$output_dir/neofetch.txt" | sed 's/^Kernel: //' | head -1)

        if [[ "$hostname" == "Unknown" ]]; then
            hostname=$(grep "^[a-z]*@" "$output_dir/neofetch.txt" | cut -d'@' -f2 | awk '{print $1}' | head -1)
        fi
    fi

    # Check for disk encryption from blockdevices.txt
    if [[ -f "$output_dir/blockdevices.txt" ]]; then
        if grep -q "crypto_LUKS" "$output_dir/blockdevices.txt"; then
            disk_encrypted="Yes (LUKS)"
        else
            disk_encrypted="No"
        fi
    fi

    # Check screen lock from screenlock-info.txt
    if [[ -f "$output_dir/screenlock-info.txt" ]]; then
        if grep -q "AUTO-LOCK-STATUS: ENABLED" "$output_dir/screenlock-info.txt"; then
            screen_lock="Yes (Auto-lock enabled)"
            # Extract the human-readable part (e.g., "10 minutes")
            local lock_time=$(grep "Total time until auto-lock:" "$output_dir/screenlock-info.txt" | grep -oP '\([0-9]+ [a-z]+\)' | tr -d '()')
            [[ -n "$lock_time" ]] && screen_lock="Yes (Auto-lock: $lock_time)"
        else
            screen_lock="Not detected / Disabled"
        fi
    fi

    # Check for Nix installation
    if [[ "$os_full" =~ "NixOS" ]]; then
        nix_installed="Yes (NixOS)"
    elif [[ -f "$output_dir/neofetch.json" ]]; then
        # Check JSON for nix packages
        local packages=$(jq -r '.packages // empty' "$output_dir/neofetch.json" 2>/dev/null)
        if [[ -n "$packages" ]] && echo "$packages" | grep -q "nix-"; then
            nix_installed="Yes"
        fi
    elif [[ -f "$output_dir/neofetch.txt" ]] && grep -q "nix-" "$output_dir/neofetch.txt"; then
        nix_installed="Yes"
    elif [[ -f "$output_dir/installed-packages.txt" ]] && grep -qi "nix" "$output_dir/installed-packages.txt"; then
        nix_installed="Yes"
    else
        nix_installed="No"
    fi

    # Check OS up-to-date status from os-kernel-status.txt
    if [[ -f "$output_dir/os-kernel-status.txt" ]]; then
        if grep -q "Result: ✓ PASS" "$output_dir/os-kernel-status.txt"; then
            os_uptodate="Yes (Current)"
        elif grep -q "Result: ⚠ WARNING" "$output_dir/os-kernel-status.txt"; then
            os_uptodate="Supported (Upgrade recommended)"
        elif grep -q "Result: ✗ FAIL" "$output_dir/os-kernel-status.txt"; then
            os_uptodate="No (EOL)"
        else
            os_uptodate="Unknown"
        fi
    fi

    # Get report date from directory name or file timestamp
    if [[ "$output_dir" =~ ([0-9]{2}-[0-9]{2}-[0-9]{4}) ]]; then
        report_date="${BASH_REMATCH[1]}"
    elif [[ -f "$output_dir/lynis-report.json" ]]; then
        report_date=$(date -r "$output_dir/lynis-report.json" +"%d-%m-%Y" 2>/dev/null)
    fi

    # Generate report
    echo "=====================================" > "$report_file"
    echo "  ASSET INVENTORY" >> "$report_file"
    echo "=====================================" >> "$report_file"
    echo "" >> "$report_file"
    echo "This table contains asset information extracted from the audit report." >> "$report_file"
    echo "" >> "$report_file"

    # Create table
    printf "%-35s | %s\n" "Field" "Value" >> "$report_file"
    printf "%-35s-+-" "-----------------------------------" >> "$report_file"
    printf "%s\n" "----------------------------------------" >> "$report_file"
    printf "%-35s | %s\n" "Hostname (Asset ID)" "$hostname" >> "$report_file"
    printf "%-35s | %s\n" "Serial Number / Model" "$model" >> "$report_file"
    printf "%-35s | %s\n" "Description" "Personal Device" >> "$report_file"
    printf "%-35s | %s\n" "OS Edition + Version" "$os_full" >> "$report_file"
    printf "%-35s | %s\n" "Kernel Version" "$kernel" >> "$report_file"
    printf "%-35s | %s\n" "Nix Installed" "$nix_installed" >> "$report_file"
    printf "%-35s | %s\n" "Disk Encryption" "$disk_encrypted" >> "$report_file"
    printf "%-35s | %s\n" "Screen Lock" "$screen_lock" >> "$report_file"
    printf "%-35s | %s\n" "Malware Scanner" "$malware_scanner" >> "$report_file"
    printf "%-35s | %s\n" "Firewall Active" "$firewall_active" >> "$report_file"
    printf "%-35s | %s\n" "OS Up-to-date" "$os_uptodate" >> "$report_file"
    printf "%-35s | %s\n" "Owner / User" "$owner" >> "$report_file"
    printf "%-35s | %s\n" "Last Audit Date" "$report_date" >> "$report_file"

    echo "" >> "$report_file"
    echo "=====================================" >> "$report_file"
    echo "Notes:" >> "$report_file"
    echo "  - Serial number may require manual verification" >> "$report_file"
    echo "  - 'No suspicious software detected' requires manual review of:" >> "$report_file"
    echo "    * installed-packages.txt" >> "$report_file"
    echo "    * lynis-report.json security warnings" >> "$report_file"
    echo "  - Defender (AV) status: See 'Malware Scanner' field" >> "$report_file"
    echo "=====================================" >> "$report_file"

    cat "$report_file"
    return 0
}

